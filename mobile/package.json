{
  "name": "yuuka-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-localization": "~57.0.0",
    "expo-router": "~57.0.4",
    "expo-screen-capture": "~57.0.0",
    "expo-secure-store": "^57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.81.0",
    "react-native": "0.86.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "prettier": "^3.9.5",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --runInBand",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "overrides": {
    "xcode": {
      "uuid": "11.1.1"
    }
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "collectCoverageFrom": [
      "src/api/{api-client,api-error,contracts}.ts",
      "src/auth/{schemas,session}.ts",
      "src/config/env.ts",
      "src/domain/**/*.ts",
      "src/features/paychecks/{entry-list,form-schemas}.ts",
      "src/settings/settings-storage.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    }
  },
  "private": true
}
