YUUKA_JWT_ACCESS_TOKEN_TTL=PT15M
YUUKA_JWT_REFRESH_TOKEN_TTL=P30D
YUUKA_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
YUUKA_HTTP_MAX_REQUEST_BODY_SIZE_BYTES=65536
